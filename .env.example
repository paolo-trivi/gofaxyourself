# GoFaxYourself — example configuration.
# Copy this file to .env and fill in your real SIP values.
#   cp .env.example .env
# NEVER commit .env: it holds your SIP credentials. (.env is gitignored.)

# --- GoFax behavior ---------------------------------------------------------

# Operating mode. Only "tape" is implemented in v0.1.
# tape   -> pre-recorded WAV files (default, fully offline)
# script -> reserved (local randomized snippets) — see docs/MODES.md
# brain  -> reserved (optional LLM + TTS, disabled)  — see docs/MODES.md
GOFAX_MODE=tape

# Language pack to use. See docs/LANGUAGE_PACKS.md (en it es fr de pt ...).
GOFAX_LANGUAGE=en

# Persona identifier (English-only ids). See docs/CONTRACTS.md.
GOFAX_PERSONA=confused-grandpa

# Audio payload played to the caller. This is the preferred public contract.
# The bundled default is a silent-ish PLACEHOLDER (a short tone + silence),
# not speech. Generate real audio with tools/generate-audio.sh, or point this
# at your own WAV. See docs/AUDIO_GENERATION.md.
GOFAX_AUDIO_FILE=./audio/en/confused-grandpa.wav

# --- SIP registration -------------------------------------------------------

# Auth username for your SIP account.
SIP_USERNAME=

# SIP password. Keep it secret. Keep it safe.
SIP_PASSWORD=

# SIP domain (the "@domain" part of your address of record: user@domain).
SIP_DOMAIN=

# SIP server / registrar / outbound proxy host. Often equal to SIP_DOMAIN.
SIP_SERVER=

# SIP signalling port.
SIP_PORT=5060

# --- Call loop --------------------------------------------------------------

# Max session length, in seconds. 0 = stay registered until you stop it.
CALL_DURATION_SECONDS=0

# Pause between call sessions, in seconds.
CALL_INTERVAL_SECONDS=5

# Sample rate of GOFAX_AUDIO_FILE. SIP-friendly default is 8000 Hz.
AUDIO_FILE_SAMPLE_RATE=8000

# --- Brain Mode (reserved, disabled by default) -----------------------------
# Documented contract only. Not wired to any provider in v0.1.
# See docs/MODES.md and docs/CONTRACTS.md.

GOFAX_LLM_ENABLED=false
GOFAX_LLM_PROVIDER=
GOFAX_LLM_MODEL=
GOFAX_LLM_API_KEY=

GOFAX_TTS_ENABLED=false
GOFAX_TTS_PROVIDER=
GOFAX_TTS_VOICE=

# --- Backward compatibility (optional, deprecated) --------------------------
# Older configs used these names. GoFax still reads them as a fallback, but
# the variables above are the supported public contract:
#   SIP_USER            -> SIP_USERNAME
#   SIP_SERVER (=domain)-> SIP_DOMAIN   (new SIP_SERVER means the proxy host)
#   SIP_OUTBOUND_PROXY  -> SIP_SERVER
#   AUDIO_FILE          -> GOFAX_AUDIO_FILE
# DNS_SERVER and SIP_TRACE remain available as optional extras.
# DNS_SERVER=
# SIP_TRACE=
