# GoFaxYourself — copy this to .env and fill it in:
#   cp .env.example .env
#   nano .env
#   docker compose up -d
#
# .env holds your SIP password — it is gitignored. NEVER commit it.

# --- SIP account (required) ---
SIP_USERNAME=
SIP_PASSWORD=
SIP_DOMAIN=                 # the @domain of your SIP address (e.g. windtre.it)
SIP_SERVER=                 # registrar / proxy host (often = SIP_DOMAIN)

# --- Audio played to callers ---
# Mono, 8000 Hz, 16-bit PCM WAV. The bundled default works out of the box.
GOFAX_AUDIO_FILE=./audio/it/anti-call-center.wav

# --- Optional ---
DNS_SERVER=                 # e.g. 192.168.1.1:53 ; empty = use system DNS
GOFAX_LOG_ENABLED=false     # true = write CDR/SIP logs to ./logs (real numbers!)
GOFAX_LOG_HASH_PEPPER=      # random secret to hash numbers in logs
GOFAX_LOG_REDACT=false      # true = drop numbers from logs entirely
